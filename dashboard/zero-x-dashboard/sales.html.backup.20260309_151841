            { company: "Sheffield - WtE Partnership", contact: "Prof. Bill Nimmo", email: "", value: 550000, stage: "meeting", source: "outreach", phone: "", notes: "Meeting proposed. Waste-to-energy collaboration." },
            
            // REPLIED
