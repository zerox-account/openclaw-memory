            { company: "GIZ Powering Agriculture - Nigeria", contact: "Katharina Meder", email: "", value: 500000, stage: "prospect", source: "partner", phone: "", notes: "€100M+ program. Nigerian Breweries target. Prospect." },
            { company: "Horizon Europe EIC Accelerator", contact: "", email: "", value: 2500000, stage: "prospect", source: "partner", phone: "", notes: "€2.5M for European scale-up. Consortium building. Prospect." },
            { company: "EU Innovation Fund - Data Centers", contact: "", email: "", value: 3000000, stage: "prospect", source: "partner", phone: "", notes: "60% CAPEX for data center pilots. Prospect." },
            { company: "Caribbean Energy Consortium", contact: "", email: "", value: 2000000, stage: "prospect", source: "outreach", phone: "", notes: "4 GW needed by 2027. $9B market. 1.4-2.4 year payback vs diesel. Prospect." },
            { company: "Pacific Islands - World Bank", contact: "", email: "", value: 1500000, stage: "prospect", source: "partner", phone: "", notes: "1.8 GW needed. $5.9B investment. Green Climate Fund $10B+. Prospect." },
            { company: "Indonesia Palm Oil Mill Consortium", contact: "", email: "", value: 5000000, stage: "prospect", source: "outreach", phone: "", notes: "800+ mills. 250-300 Mt EFB/year. 70% underutilized. $400K-800K/year per mill. Prospect." },
            { company: "Malaysia MSPO Certification", contact: "", email: "", value: 3000000, stage: "prospect", source: "outreach", phone: "", notes: "450+ mills. B20 biodiesel mandate. MSPO certification mandatory. Prospect." }
        ];
        
        // Load leads from localStorage or use defaults
        let leads = JSON.parse(localStorage.getItem('zerox_sales_leads_v2') || 'null');
        if (!leads || leads.length === 0) {
            leads = defaultLeads;
            localStorage.setItem('zerox_sales_leads_v2', JSON.stringify(leads));
        }
        
        const stageColors = {
            prospect: 'bg-gray-500/20 text-gray-400 border-gray-500/30',
            contacted: 'bg-blue-500/20 text-blue-400 border-blue-500/30',
            replied: 'bg-cyan-500/20 text-cyan-400 border-cyan-500/30',
            meeting: 'bg-amber-500/20 text-amber-400 border-amber-500/30',
            qualified: 'bg-green-500/20 text-green-400 border-green-500/30',
            proposal: 'bg-purple-500/20 text-purple-400 border-purple-500/30',
            approved: 'bg-purple-600/30 text-purple-300 border-purple-500/50'
        };
        
        const stageProbabilities = {
            prospect: 0.05,
            contacted: 0.1,
            replied: 0.2,
            meeting: 0.35,
            qualified: 0.5,
            proposal: 0.75,
            approved: 1.0
        };
        
        function renderPipeline() {
            // Clear all columns
            ['prospect', 'contacted', 'replied', 'meeting', 'qualified', 'proposal', 'approved'].forEach(stage => {
                document.getElementById(`column-${stage}`).innerHTML = '';
                document.getElementById(`count-${stage}`).textContent = '0';
            });
            
            // Group leads by stage
            const leadsByStage = {};
            leads.forEach(lead => {
                if (!leadsByStage[lead.stage]) leadsByStage[lead.stage] = [];
                leadsByStage[lead.stage].push(lead);
            });
            
            // Render each column
            let totalValue = 0;
            let weightedValue = 0;
            let approvedValue = 0;
            
            Object.keys(leadsByStage).forEach(stage => {
                const column = document.getElementById(`column-${stage}`);
                const count = leadsByStage[stage].length;
                document.getElementById(`count-${stage}`).textContent = count;
                
                leadsByStage[stage].forEach((lead, index) => {
                    const val = parseInt(lead.value || 0);
                    totalValue += val;
                    weightedValue += val * stageProbabilities[stage];
                    if (stage === 'approved') approvedValue += val;
                    
                    const card = document.createElement('div');
                    card.className = 'lead-card';
                    card.innerHTML = `
                        <div class="flex justify-between items-start mb-2">
                            <span class="stage-badge ${stageColors[stage]}">${stage}</span>
                            <button onclick="deleteLead(${leads.indexOf(lead)})" class="text-gray-500 hover:text-red-400"><i data-lucide="x" class="w-4 h-4"></i></button>
                        </div>
                        <h4 class="font-semibold text-white text-sm mb-1">${lead.company}</h4>
                        <p class="text-xs text-gray-400 mb-2">${lead.contact}</p>
                        <div class="value-tag">€${(val / 1000000).toFixed(1)}M</div>
                        ${lead.notes ? `<p class="text-xs text-gray-500 mt-2 line-clamp-2">${lead.notes}</p>` : ''}
                    `;
                    column.appendChild(card);
                });
            });
            
            // Update stats
            document.getElementById('totalValue').textContent = '€' + (totalValue / 1000000).toFixed(1) + 'M';
            document.getElementById('weightedValue').textContent = '€' + (weightedValue / 1000000).toFixed(1) + 'M';
            document.getElementById('approvedValue').textContent = '€' + (approvedValue / 1000000).toFixed(1) + 'M';
            document.getElementById('totalDeals').textContent = leads.length;
            
            lucide.createIcons();
        }
        
        function openModal() { document.getElementById('addLeadModal').classList.add('active'); }
        function closeModal() { document.getElementById('addLeadModal').classList.remove('active'); document.getElementById('addLeadForm').reset(); }
        
        function deleteLead(index) {
            if (confirm('Remove this opportunity?')) {
                leads.splice(index, 1);
                localStorage.setItem('zerox_sales_leads_v2', JSON.stringify(leads));
                renderPipeline();
            }
        }
        
        document.getElementById('addLeadForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const formData = new FormData(e.target);
            leads.push({
                company: formData.get('company'),
                contact: formData.get('contact'),
                email: formData.get('email'),
                phone: formData.get('phone'),
                value: formData.get('value'),
                stage: formData.get('stage'),
                source: formData.get('source'),
                notes: formData.get('notes')
            });
            localStorage.setItem('zerox_sales_leads_v2', JSON.stringify(leads));
            closeModal();
            renderPipeline();
        });
        
        document.getElementById('addLeadModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });
        
        // Initial render
        renderPipeline();
    </script>
</body>
</html>
