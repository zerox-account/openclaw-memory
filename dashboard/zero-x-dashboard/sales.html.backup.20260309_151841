            { company: "TUM - Catalyst Characterization", contact: "Prof. Marc Ledendecker", email: "", value: 500000, stage: "qualified", source: "outreach", phone: "", notes: "INTERESTED in catalyst collaboration. Zoom call proposed. Qualified lead." },
            { company: "GIZ develoPPP - Indonesia EFB", contact: "develoPPP@giz.de", email: "", value: 500000, stage: "qualified", source: "partner", phone: "+49 6196 796555", notes: "Spring Round 2026. €250K grant + €250K private. PT PMA partner needed. Deadline: March 31, 2026." },
            
