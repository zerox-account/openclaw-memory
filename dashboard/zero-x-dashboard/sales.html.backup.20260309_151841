    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        :root { --background: #0A0F0A; --card: #121A12; --border: #1F3D1F; --primary: #22C55E; }
        * { font-family: 'Inter', sans-serif; }
        body { background: var(--background); color: #F8FAFC; }
        .glass { background: rgba(18, 26, 18, 0.8); backdrop-filter: blur(12px); border: 1px solid var(--border); }
        .nav-item:hover { background: rgba(34, 197, 94, 0.1); border-left: 3px solid var(--primary); }
        .nav-item.active { background: rgba(34, 197, 94, 0.15); border-left: 3px solid var(--primary); }
        .pipeline-column { background: rgba(18, 26, 18, 0.6); border: 1px solid var(--border); border-radius: 12px; min-height: 500px; }
        .lead-card { background: linear-gradient(135deg, rgba(31, 61, 31, 0.4) 0%, rgba(18, 26, 18, 0.8) 100%); border: 1px solid var(--border); border-radius: 12px; padding: 16px; margin-bottom: 12px; cursor: grab; transition: all 0.2s; }
        .lead-card:hover { border-color: rgba(34, 197, 94, 0.3); transform: translateY(-2px); }
        .stage-badge { font-size: 10px; padding: 3px 8px; border-radius: 20px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px; }
        .value-tag { font-size: 16px; font-weight: 700; color: #22C55E; }
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.8); z-index: 100; align-items: center; justify-content: center; }
        .modal.active { display: flex; }
        .modal-content { background: var(--card); border: 1px solid var(--border); border-radius: 12px; width: 90%; max-width: 600px; max-height: 90vh; overflow-y: auto; }
        .form-input { width: 100%; background: var(--background); border: 1px solid var(--border); border-radius: 8px; padding: 10px 14px; color: #F8FAFC; font-size: 14px; margin-top: 6px; }
        .form-input:focus { outline: none; border-color: var(--primary); }
        .stats-card { background: linear-gradient(135deg, rgba(34, 197, 94, 0.1) 0%, rgba(6, 182, 212, 0.1) 100%); border: 1px solid rgba(34, 197, 94, 0.2); }
    </style>
</head>
