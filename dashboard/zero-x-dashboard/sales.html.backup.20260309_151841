            { company: "Glasgow - ML Gasification", contact: "Dr. Siming You", email: "", value: 350000, stage: "replied", source: "outreach", phone: "", notes: "Replied with interest. Machine learning for gasification optimization." },
            { company: "Strathmore University Kenya", contact: "Dr. Maranga", email: "", value: 500000, stage: "replied", source: "outreach", phone: "", notes: "Reply received. Research partnership + potential pilot." },
            
            // CONTACTED
            { company: "REA Nigeria - DARES Program", contact: "Dr. Abba Aliyu", email: "a@rea.gov.ng", value: 5000000, stage: "contacted", source: "outreach", phone: "", notes: "$750M rural electrification fund. 39% electrification rate. Contacted, awaiting reply." },
            { company: "Kenya Rural Electrification (REREC)", contact: "Alex Kamau Wachira", email: "psenergy@energy.go.ke", value: 2000000, stage: "contacted", source: "outreach", phone: "", notes: "KfW GET FiT program. Strong mobile money ecosystem (M-Pesa). Contacted." },
            { company: "NEOM - CleanTech/Sustainability", contact: "Peter Hlavnicka", email: "peterhlavnicka@gmail.com", value: 10000000, stage: "contacted", source: "referral", phone: "", notes: "Peter is intermediary. Email sent Feb 10. Zero waste, circular economy focus." },
            { company: "Meta - Prometheus Supercluster", contact: "", email: "", value: 5000000, stage: "contacted", source: "outreach", phone: "", notes: "Ohio. 1 GW supercluster. Trigeneration opportunity. Contacted." },
            
            // PROSPECT
            { company: "Puro.earth - CORC Certification", contact: "", email: "", value: 150000, stage: "prospect", source: "partner", phone: "", notes: "€140-160/tCO2e. 500-1,000 tCO2e/year per unit. Certification pathway. Prospect stage." },
            { company: "Microsoft - Carbon Removal", contact: "", email: "", value: 500000, stage: "prospect", source: "partner", phone: "", notes: "Long-term offtake agreement target. Prospect." },
            { company: "Shopify - Carbon Credits", contact: "", email: "", value: 300000, stage: "prospect", source: "partner", phone: "", notes: "Target buyer for biochar carbon credits. Prospect." },
            { company: "atNorth - District Heating", contact: "", email: "", value: 2000000, stage: "prospect", source: "outreach", phone: "", notes: "Nordics. DEN01 heats 8,000+ homes. PUE <1.2. Prospect." },
            { company: "Google Singapore - Tropical Cooling", contact: "", email: "", value: 3000000, stage: "prospect", source: "outreach", phone: "", notes: "Tropical cooling challenge. Absorption chiller integration. Prospect." },
