            { company: "African Mining Consortium", contact: "", email: "", value: 3000000, stage: "prospect", source: "outreach", phone: "", notes: "Diesel replacement. $0.08-0.12/kWh vs $0.85-1.20/liter diesel. Prospect." },
            { company: "PlanET Biogas - Partnership", contact: "", email: "", value: 2000000, stage: "prospect", source: "partner", phone: "", notes: "Co-marketing agreement. 9,500 German biogas plants. €350M retrofit market. Prospect." },
            { company: "HoSt - Co-Marketing", contact: "", email: "", value: 1500000, stage: "prospect", source: "partner", phone: "", notes: "DIGEST+ Horizon Call €2.5M. +15-25% methane capture. Prospect." },
